<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      Base theme used before Compose takes over. Compose's TodoAppTheme
      overrides almost everything once setContent { ... } is called.
    -->
    <style name="Theme.TodoList" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">#0F172A</item>
        <item name="android:navigationBarColor">#0F172A</item>
        <item name="android:windowBackground">#0F172A</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
